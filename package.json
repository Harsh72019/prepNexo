{
  "name": "interview-battlefield",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "verify": "pnpm typecheck && pnpm test && pnpm build",
    "prod:check": "pnpm db:generate && pnpm verify",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @interview-battlefield/auth-service prisma:generate",
    "db:migrate": "pnpm --filter @interview-battlefield/auth-service prisma:migrate",
    "db:seed": "pnpm --filter @interview-battlefield/auth-service prisma:seed",
    "question-bank:seed": "pnpm --filter @interview-battlefield/auth-service question-bank:seed"
  },
  "devDependencies": {
    "@interview-battlefield/config": "workspace:*",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
