{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@interview-battlefield/ui/*": ["packages/ui/src/*"],
      "@interview-battlefield/types": ["packages/types/src/index.ts"],
      "@interview-battlefield/config/*": ["packages/config/src/*"]
    }
  }
}
